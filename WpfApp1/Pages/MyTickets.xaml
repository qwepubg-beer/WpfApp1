<Page x:Class="WpfApp1.Pages.MyTickets"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="800"
      Title="MyTickets">

    <Grid>
        <StackPanel>
            <TextBlock Name="Mes" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" Text="Ваши билеты:" VerticalAlignment="Top" Width="500"/>
            <ListBox Name="Tickets" d:ItemsSource="{d:SampleData ItemCount=5}" IsEnabled="False" Margin="150,10,150,0" Height="384">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel HorizontalAlignment="Center">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Padding="15" Text="{Binding Seat, StringFormat=Место: {0}}"/>
                                <TextBlock Padding="15" Text="{Binding Genre, StringFormat=Цена: {0}}"/>
                                <TextBlock Padding="15" Text="{Binding Age+}"/>
                            </StackPanel>
                            <Button Height="40" Content="Удалить" Click="Button_Click"></Button>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </StackPanel>
    </Grid>
</Page>
