<Page x:Class="WpfApp1.Pages.MyTickets"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="800"
      Title="MyTickets">

    <Grid>
            <ListBox x:Name="MyTickList" SelectionChanged="FilmList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="1,0,1,16" Width="798">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel HorizontalAlignment="Center">
                            <Image Height="100" Width="160"  Source="{Binding film.Image}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Padding="5" Text="{Binding film.Name}"/>
                                <TextBlock Padding="5" Text="{Binding film.Genre, StringFormat=Жанр: {0}}"/>
                                <TextBlock Padding="5" Text="{Binding session.Start_date, StringFormat=Дата: {0}}"/>
                                <TextBlock Padding="5" Text="{Binding session.Price, StringFormat=Цена: {0}}"/>
                                <TextBlock Padding="5" Text="{Binding ticket.SeatNumber, StringFormat=Место: {0}}"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
    </Grid>
</Page>
