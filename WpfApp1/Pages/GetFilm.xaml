<Page x:Class="WpfApp1.Pages.GetFilm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="800"
      Title="GetFilm">

    <Grid>
        <StackPanel  Margin="0,28,0,2" HorizontalAlignment="Left" Width="425">
            <Image Source="{Binding Image}" Height="100" Width="300" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}" Padding="10" />
                <TextBlock Text="{Binding ReleaseDate}" Padding="10"/>
                <TextBlock Text="{Binding Genre}" Padding="10" />
                <TextBlock Text="{Binding Description}" Padding="10" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Age, StringFormat=Возраст: {0}+}" Padding="10" />
                <Button Content="Купить билет" HorizontalAlignment="Center" VerticalAlignment="Top" Width="224" Height="35"  Click="Button_Click_1" Padding="5"/>
            </StackPanel>
        </StackPanel>
        <ListBox x:Name="ActorsList" SelectionChanged="Session_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="430,0,0,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Height="100" Width="160"  Source="{Binding Image}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Padding="15" Text="{Binding Name}"/>
                            <TextBlock Padding="15" Text="{Binding Age, StringFormat=Возраст: {0}}"/>
                            <TextBlock Padding="15" Text="{Binding Description}" TextWrapping="Wrap"/>
                        </StackPanel>
                </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        <Button Content="Вернуться назад" HorizontalAlignment="Left" VerticalAlignment="Top" Width="103" Height="23" Click="Button_Click"/>
    </Grid>
</Page>
