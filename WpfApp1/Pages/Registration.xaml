<Page x:Class="WpfApp1.Pages.Registration"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="800"
      Title="Registration">

    <Grid>
        <StackPanel Margin="207,0,207,104">
            <Label Content="E-mail" HorizontalAlignment="Center"/>
            <TextBox Name="mail" TextWrapping="Wrap" Text="" Width="150"/>
            <Label Content="Логин" Margin="0,8" HorizontalAlignment="Center"/>
            <TextBox Name ="login" TextWrapping="Wrap" Text="" Width="150"/>
            <Label Content="Пароль" Margin="0,8" HorizontalAlignment="Center"/>
            <TextBox Name="p1" TextWrapping="Wrap" Text="" Width="150"/>
            <Label Content="Повторите пароль" Margin="0,8" HorizontalAlignment="Center"/>
            <TextBox Name ="p2" TextWrapping="Wrap" Text="" Width="150"/>
            <Button Content="Зарегестрироваться" Margin="0,8" Click="Button_Click"/>
        </StackPanel>

    </Grid>
</Page>
