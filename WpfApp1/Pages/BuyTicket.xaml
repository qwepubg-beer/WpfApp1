<Page x:Class="WpfApp1.Pages.BuyTicket"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="800"
      Title="BuyTicket">

    <Grid>
        <ListBox x:Name="Tickets" SelectionChanged="Session_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Center">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Padding="5" Text="{Binding Film, StringFormat=Фильм: {0}}"/>
                            <TextBlock Padding="5" Text="{Binding Session.Start_date, StringFormat=начало: {0}}"/>
                            <TextBlock Padding="5" Text="{Binding Number, StringFormat=Зал номер: {0}}"/>
                            <TextBlock Padding="5" Text="{Binding Session.Price, StringFormat=Цена: {0}}"/>
                        </StackPanel>
                        <Button Height="40" Content="Купить билеты" Click="Button_Click"></Button>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>
