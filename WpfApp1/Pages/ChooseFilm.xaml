<Page x:Class="WpfApp1.Pages.ChooseFilm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="800"
      Title="ChooseFilm">

    <Grid>
        <Button Content="Поиск" HorizontalAlignment="Left" Margin="532,0,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click_1"/>
        <TextBox Name="TextSearch" HorizontalAlignment="Left" Margin="400,0,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Height="20" />
        <Slider Name ="Rating" HorizontalAlignment="Left" Margin="206,1,0,0" VerticalAlignment="Top" Width="100" Maximum="10" Minimum="0" ValueChanged="Rating_ValueChanged"/>
        <ListBox x:Name="FilmList" SelectionChanged="FilmList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,26,0,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Center">
                        <Image Height="100" Width="160"  Source="{Binding Image}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Padding="15" Text="{Binding Name}"/>
                            <TextBlock Padding="15" Text="{Binding Genre, StringFormat=Жанр: {0}}"/>
                            <TextBlock Padding="15" Text="{Binding Rating, StringFormat=Рейтинг: {0}}"/>
                            <TextBlock Padding="15" Text="{Binding Age, StringFormat=Возраст: {0}+}"/>
                        </StackPanel>
                        <Button Height="40" Content="Информация" Click="Button_Click"></Button>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        <TextBlock Name="R" HorizontalAlignment="Left" Margin="311,2,0,0" TextWrapping="Wrap" Text="Рейтинг >" VerticalAlignment="Top"/>

    </Grid>
</Page>
